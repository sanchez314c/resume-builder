{
  "name": "resume-builder",
  "version": "1.0.0",
  "description": "AI-powered desktop application for generating professional resumes",
  "main": "dist/main/index.js",
  "author": {
    "name": "J. Michaels",
    "url": "https://github.com/sanchez314c"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanchez314c/resume-builder.git"
  },
  "bugs": {
    "url": "https://github.com/sanchez314c/resume-builder/issues"
  },
  "homepage": "https://github.com/sanchez314c/resume-builder#readme",
  "keywords": [
    "electron",
    "resume",
    "ai",
    "nlp",
    "desktop"
  ],
  "scripts": {
    "start": "ELECTRON_NO_SANDBOX=1 electron . --no-sandbox",
    "dev": "ELECTRON_NO_SANDBOX=1 electron-vite dev",
    "dev:linux": "ELECTRON_DISABLE_SANDBOX=1 ELECTRON_NO_SANDBOX=1 electron-vite dev",
    "build": "electron-vite build",
    "build:all": "electron-vite build && electron-builder --linux --win --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "preview": "electron-vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf dist out node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0",
    "@tanstack/react-query": "^5.0.0",
    "pdf-lib": "^1.17.1",
    "recharts": "^2.10.0",
    "lucide-react": "^0.294.0",
    "better-sqlite3": "^9.2.0",
    "drizzle-orm": "^0.29.0",
    "uuid": "^9.0.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.10.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^9.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@playwright/test": "^1.40.0",
    "electron": "^28.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/user-event": "^14.5.0",
    "jsdom": "^23.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
